<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Find Your Dream Home</h1>
  <p class="text-gray-500 mt-2">Browse our curated collection of premium properties</p>
</div>
<% if @properties.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @properties.each do |property| %>
      <%= link_to property_path(property), class: "group bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-xl hover:border-blue-200 transition-all duration-300" do %>
        <% if property.image_url.present? %>
          <div class="h-48 bg-gray-100 overflow-hidden">
            <img src="<%= property.image_url %>" alt="<%= property.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
          </div>
        <% else %>
          <div class="h-48 bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
            <svg class="w-16 h-16 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
        <% end %>
        <div class="p-5">
          <h3 class="text-lg font-semibold text-gray-900 group-hover:text-blue-600 transition-colors mb-1"><%= property.title %></h3>
          <p class="text-gray-500 text-sm mb-3 flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <%= property.address %>
          </p>
          <p class="text-gray-600 text-sm line-clamp-2 mb-4"><%= property.description %></p>
          <div class="flex items-center justify-between">
            <span class="text-xl font-bold text-green-600">Rs <%= number_with_delimiter(property.price) %></span>
            <span class="text-sm text-blue-600 font-medium group-hover:translate-x-1 transition-transform">View Details →</span>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-16 bg-white rounded-2xl border border-gray-100">
    <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
    </svg>
    <p class="text-gray-500">No properties available yet.</p>
  </div>
<% end %>
