<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Find Your Dream Home</h1>
  <p class="text-gray-500 dark:text-gray-400 mt-2">Browse our curated collection of premium properties</p>
</div>
<div class="mb-6">
  <%= form_with url: properties_path, method: :get, class: "flex gap-2" do %>
    <%= text_field_tag :search, params[:search], placeholder: "Search by title, description or price...", class: "flex-1 px-4 py-2 rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    <%= submit_tag "Search", class: "px-6 py-2 bg-gradient-to-r from-blue-500 to-indigo-600 text-white rounded-xl font-medium hover:from-blue-600 hover:to-indigo-700 transition-all" %>
    <% if params[:search].present? %>
      <%= link_to "Clear", properties_path, class: "px-4 py-2 text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white" %>
    <% end %>
  <% end %>
</div>
<% if @properties.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @properties.each do |property| %>
      <%= link_to property_path(property), class: "group bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden hover:shadow-xl hover:border-blue-200 dark:hover:border-blue-500 transition-all duration-300" do %>
        <% if property.image_url.present? %>
          <div class="h-48 bg-gray-100 dark:bg-gray-700 overflow-hidden">
            <img src="<%= property.image_url %>" alt="<%= property.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
          </div>
        <% else %>
          <div class="h-48 bg-gradient-to-br from-gray-100 to-gray-200 dark:from-gray-700 dark:to-gray-600 flex items-center justify-center">
            <svg class="w-16 h-16 text-gray-300 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
        <% end %>
        <div class="p-5">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors mb-1"><%= property.title %></h3>
          <p class="text-gray-500 dark:text-gray-400 text-sm mb-3 flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <%= property.address %>
          </p>
          <p class="text-gray-600 dark:text-gray-300 text-sm line-clamp-2 mb-4"><%= property.description %></p>
          <div class="flex items-center justify-between">
            <span class="text-xl font-bold text-green-600 dark:text-green-400">Rs <%= number_with_delimiter(property.price) %></span>
            <span class="text-sm text-blue-600 dark:text-blue-400 font-medium group-hover:translate-x-1 transition-transform">View Details →</span>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-16 bg-white dark:bg-gray-800 rounded-2xl border border-gray-100 dark:border-gray-700">
    <svg class="w-16 h-16 text-gray-300 dark:text-gray-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
    </svg>
    <p class="text-gray-500 dark:text-gray-400">No properties available yet.</p>
  </div>
<% end %>
