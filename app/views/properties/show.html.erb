<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
  <!-- Property Image -->
  <% if @property.image_url.present? %>
    <div class="h-80 bg-gray-100 overflow-hidden">
      <img src="<%= @property.image_url %>" alt="<%= @property.title %>" class="w-full h-full object-cover">
    </div>
  <% else %>
    <div class="h-64 bg-gradient-to-br from-blue-50 to-indigo-100 flex items-center justify-center">
      <svg class="w-24 h-24 text-blue-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
      </svg>
    </div>
  <% end %>
  <div class="p-6 sm:p-8">
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-6">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2"><%= @property.title %></h1>
        <p class="text-gray-500 flex items-center gap-2">
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <%= @property.address %>
        </p>
      </div>
      <div class="text-left sm:text-right">
        <p class="text-sm text-gray-500 mb-1">Asking Price</p>
        <p class="text-3xl font-bold text-green-600">Rs <%= number_with_delimiter(@property.price) %></p>
      </div>
    </div>
    <div class="border-t border-gray-100 pt-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">Description</h2>
      <p class="text-gray-600 leading-relaxed"><%= @property.description %></p>
    </div>
    <div class="border-t border-gray-100 pt-6 mt-6">
      <% if user_signed_in? %>
        <% if @favourited %>
          <div class="flex items-center gap-4">
            <div class="flex items-center gap-2 text-green-600">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
              <span class="font-medium">In your favorites</span>
            </div>
            <%= button_to "Remove from Favorites", favourite_property_path(@property), method: :delete, class: "px-6 py-2.5 bg-red-50 text-red-600 rounded-xl hover:bg-red-100 transition-colors font-medium flex items-center gap-2" %>
          </div>
        <% else %>
          <%= button_to "Add to Favorites", favourite_property_path(@property), method: :post, class: "px-6 py-2.5 bg-gradient-to-r from-blue-500 to-indigo-600 text-white rounded-xl hover:from-blue-600 hover:to-indigo-700 transition-all duration-200 font-medium flex items-center gap-2 shadow-md hover:shadow-lg" %>
        <% end %>
      <% else %>
        <div class="bg-blue-50 rounded-xl p-4 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
            </div>
            <div>
              <p class="text-blue-900 font-medium">Save this property</p>
              <p class="text-blue-600 text-sm">Log in to add to your favorites</p>
            </div>
          </div>
          <%= link_to "Login", new_user_session_path, class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
<%= link_to properties_path, class: "inline-flex items-center gap-2 text-gray-600 hover:text-blue-600 transition-colors mt-6 font-medium" do %>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
  </svg>
  Back to Properties
<% end %>
