<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <%= link_to "← Back to Admin", admin_properties_path, class: "text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400" %>
  </div>
  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-6"><%= @property.persisted? ? "Edit Property" : "Add New Property" %></h1>
    <%= form_with model: [:admin, @property], local: true do |f| %>
      <div class="space-y-5">
        <div>
          <%= f.label :title, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5" %>
          <%= f.text_field :title, class: "w-full px-4 py-2.5 border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500", required: true %>
        </div>
        <div>
          <%= f.label :address, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5" %>
          <%= f.text_field :address, class: "w-full px-4 py-2.5 border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500", required: true %>
        </div>
        <div>
          <%= f.label :price, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5" %>
          <%= f.number_field :price, class: "w-full px-4 py-2.5 border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500", required: true, min: 0 %>
        </div>
        <div>
          <%= f.label :image_url, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5" %>
          <%= f.url_field :image_url, class: "w-full px-4 py-2.5 border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500", placeholder: "https://example.com/image.jpg" %>
        </div>
        <div>
          <%= f.label :description, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5" %>
          <%= f.text_area :description, rows: 4, class: "w-full px-4 py-2.5 border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>
        <div class="flex gap-3 pt-4">
          <%= f.submit @property.persisted? ? "Update Property" : "Create Property", class: "flex-1 py-2.5 bg-gradient-to-r from-blue-500 to-indigo-600 text-white font-semibold rounded-xl hover:from-blue-600 hover:to-indigo-700 transition-all duration-200" %>
          <%= link_to "Cancel", admin_properties_path, class: "px-6 py-2.5 border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-300 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
</div>
