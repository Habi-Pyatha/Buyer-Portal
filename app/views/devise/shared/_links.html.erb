<%- if controller_name != 'sessions' %>
  <p class="mt-4 text-center">Already have an account? <%= link_to "Log in", new_session_path(resource_name), class: "text-blue-600 hover:underline" %></p>
<% end %>
<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <p class="mt-2 text-center">Don't have an account? <%= link_to "Sign up", new_registration_path(resource_name), class: "text-blue-600 hover:underline" %></p>
<% end %>
